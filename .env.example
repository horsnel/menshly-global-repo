# Menshly Global — Environment Variables
# Copy this file to .env and fill in your API keys
# NEVER commit .env to git!

# ── AI Model Configuration ──
# Option 1: Groq (FREE — recommended, works globally, very fast)
AI_API_KEY=your-groq-api-key-here
AI_API_BASE=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile

# Option 2: DeepSeek (cheap, high quality)
# AI_API_KEY=your-deepseek-api-key-here
# AI_API_BASE=https://api.deepseek.com/v1
# AI_MODEL=deepseek-chat

# Option 3: Google Gemini (FREE but geo-restricted — NOT available in Nigeria/Africa)
# AI_API_KEY=your-gemini-api-key-here
# AI_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai
# AI_MODEL=gemini-2.0-flash

# Option 4: OpenAI (premium, expensive)
# AI_API_KEY=your-openai-api-key-here
# AI_API_BASE=https://api.openai.com/v1
# AI_MODEL=gpt-4o

# ── Optional: Playbook-specific model (override for premium quality) ──
# PLAYBOOK_API_KEY=your-key-here
# PLAYBOOK_API_BASE=https://api.deepseek.com/v1
# PLAYBOOK_MODEL=deepseek-chat
